<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="28dp">

        <!-- Mirror emoji -->
        <TextView
            android:text="🪞"
            android:textSize="52sp"
            android:gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="10dp" />

        <!-- App name -->
        <TextView
            android:text="MIRROR"
            android:textColor="#C0A062"
            android:textSize="18sp"
            android:letterSpacing="0.3"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:text="NATURAL LOOK"
            android:textColor="#66C0A062"
            android:textSize="10sp"
            android:letterSpacing="0.5"
            android:gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" />

        <!-- Gold divider -->
        <View
            android:layout_width="40dp"
            android:layout_height="1dp"
            android:background="#40C0A062"
            android:layout_marginVertical="14dp" />

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:text="Your 30-day free trial has ended"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tvSubtitle"
            android:text="Unlock lifetime ad-free access for a one-time payment."
            android:textColor="#66FFFFFF"
            android:textSize="13sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp" />

        <!-- Premium card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_premium"
            android:padding="20dp"
            android:layout_marginBottom="14dp">

            <!-- Price row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:text="Lifetime Premium"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:text="One-time · No subscription ever"
                        android:textColor="#55FFFFFF"
                        android:textSize="11sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:text="$5"
                        android:textColor="#C0A062"
                        android:textSize="34sp"
                        android:textStyle="bold"
                        android:fontFamily="serif"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:lineSpacingMultiplier="0.9" />

                    <TextView
                        android:text="USD · ONCE"
                        android:textColor="#44C0A062"
                        android:textSize="9sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </LinearLayout>

            <!-- Feature list -->
            <TextView android:text="✦   Zero ads, forever"
                android:textColor="#99FFFFFF" android:textSize="12sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginBottom="7dp" />
            <TextView android:text="✦   Dark &amp; Silver mirror themes"
                android:textColor="#99FFFFFF" android:textSize="12sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginBottom="7dp" />
            <TextView android:text="✦   Full-screen natural view"
                android:textColor="#99FFFFFF" android:textSize="12sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginBottom="7dp" />
            <TextView android:text="✦   Restore on any device"
                android:textColor="#99FFFFFF" android:textSize="12sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" />

            <!-- Unlock button -->
            <Button
                android:id="@+id/btnUnlock"
                android:text="Unlock for $5  →"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#0A0A0A"
                android:backgroundTint="#C0A062"
                style="@style/Widget.Material3.Button" />
        </LinearLayout>

        <!-- Continue with ads -->
        <Button
            android:id="@+id/btnContinueWithAds"
            android:text="Continue with ads"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:textSize="13sp"
            android:textColor="#44FFFFFF"
            android:backgroundTint="#11FFFFFF"
            android:layout_marginBottom="12dp"
            style="@style/Widget.Material3.Button.OutlinedButton" />

        <!-- Restore -->
        <TextView
            android:id="@+id/btnRestore"
            android:text="Restore previous purchase"
            android:textColor="#55C0A062"
            android:textSize="12sp"
            android:gravity="center"
            android:paddingVertical="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paintFlags="8"
            android:layout_marginBottom="8dp" />

        <!-- Legal note -->
        <TextView
            android:text="Secure payment via Google Play\nPurchase restores automatically across devices"
            android:textColor="#22FFFFFF"
            android:textSize="10sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.8"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>
