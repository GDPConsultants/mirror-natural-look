<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mirrorContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <View android:id="@+id/mirrorBackground"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="@drawable/bg_mirror_dark"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>

    <androidx.camera.view.PreviewView android:id="@+id/viewFinder"
        android:layout_width="match_parent" android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
        app:scaleType="fillCenter"/>

    <com.mirrornaturallook.MirrorOverlayView android:id="@+id/mirrorOverlay"
        android:layout_width="match_parent" android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- Camera blocked message -->
    <LinearLayout android:id="@+id/cameraBlockedLayout"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="center"
        android:visibility="gone" android:padding="32dp"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
        <TextView android:text="📷" android:textSize="52sp" android:gravity="center"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="16dp"/>
        <TextView android:text="Camera Access Required"
            android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"
            android:gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="8dp"/>
        <TextView android:text="Settings → Apps → Mirror → Permissions → Camera → Allow"
            android:textColor="#99FFFFFF" android:textSize="12sp" android:gravity="center"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="24dp"/>
        <Button android:id="@+id/btnAllowCamera" android:text="Allow Camera"
            android:layout_width="wrap_content" android:layout_height="48dp"
            android:paddingHorizontal="28dp" android:backgroundTint="#C0A062"
            android:textColor="#0A0A0A" android:textStyle="bold"/>
    </LinearLayout>

    <!-- Controls overlay (auto-hides) -->
    <LinearLayout android:id="@+id/controlsOverlay"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent">

        <!-- Top bar -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingHorizontal="14dp" android:paddingTop="44dp" android:paddingBottom="10dp"
            android:background="@drawable/gradient_top_fade">
            <Button android:id="@+id/btnTheme" android:text="☽  Dark"
                android:layout_width="wrap_content" android:layout_height="34dp"
                android:paddingHorizontal="14dp" android:textSize="10sp"
                android:textColor="#CCFFFFFF" android:backgroundTint="#1AFFFFFF"
                style="@style/Widget.Material3.Button.OutlinedButton"/>
            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>
            <Button android:id="@+id/btnUpgrade" android:text="28d free · $5"
                android:layout_width="wrap_content" android:layout_height="34dp"
                android:paddingHorizontal="14dp" android:textSize="10sp"
                android:textColor="#0A0A0A" android:textStyle="bold" android:backgroundTint="#C0A062"
                style="@style/Widget.Material3.Button"/>
        </LinearLayout>

        <!-- Mirror effects row -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal" android:orientation="horizontal"
            android:gravity="center" android:paddingHorizontal="12dp" android:paddingVertical="4dp"
            android:background="@drawable/bg_zoom_bar_dark" android:layout_marginTop="8dp">
            <Button android:id="@+id/btnSilverTint" android:text="✦ Tint"
                android:layout_width="wrap_content" android:layout_height="30dp"
                android:paddingHorizontal="10dp" android:textSize="9sp"
                android:textColor="#CCFFFFFF" android:backgroundTint="#22FFFFFF"
                android:layout_marginHorizontal="3dp" style="@style/Widget.Material3.Button"/>
            <Button android:id="@+id/btnEdgeGlow" android:text="◎ Glow"
                android:layout_width="wrap_content" android:layout_height="30dp"
                android:paddingHorizontal="10dp" android:textSize="9sp"
                android:textColor="#CCFFFFFF" android:backgroundTint="#22FFFFFF"
                android:layout_marginHorizontal="3dp" style="@style/Widget.Material3.Button"/>
            <Button android:id="@+id/btnFrostedBorder" android:text="❄ Frame"
                android:layout_width="wrap_content" android:layout_height="30dp"
                android:paddingHorizontal="10dp" android:textSize="9sp"
                android:textColor="#CCFFFFFF" android:backgroundTint="#22FFFFFF"
                android:layout_marginHorizontal="3dp" style="@style/Widget.Material3.Button"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>

        <!-- Zoom badge -->
        <TextView android:id="@+id/zoomBadge"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal" android:text="1.0×"
            android:textColor="#BBFFFFFF" android:textSize="11sp"
            android:background="@drawable/badge_bg" android:paddingHorizontal="14dp"
            android:paddingVertical="3dp" android:visibility="gone" android:layout_marginBottom="6dp"/>

        <!-- Zoom buttons -->
        <LinearLayout android:id="@+id/zoomBar"
            android:layout_width="wrap_content" android:layout_height="44dp"
            android:orientation="horizontal" android:layout_gravity="center_horizontal"
            android:gravity="center_vertical" android:paddingHorizontal="12dp"
            android:layout_marginBottom="14dp" android:background="@drawable/bg_zoom_bar_dark">
            <Button android:id="@+id/zoom1x"  style="@style/ZoomButton" android:text="1×"   android:selected="true"/>
            <Button android:id="@+id/zoom15x" style="@style/ZoomButton" android:text="1.5×"/>
            <Button android:id="@+id/zoom2x"  style="@style/ZoomButton" android:text="2×"/>
            <Button android:id="@+id/zoom25x" style="@style/ZoomButton" android:text="2.5×"/>
            <Button android:id="@+id/zoom3x"  style="@style/ZoomButton" android:text="3×"/>
        </LinearLayout>

        <!-- Watch ad -->
        <Button android:id="@+id/btnWatchAd" android:text="Watch ad → 1hr no ads"
            android:layout_width="wrap_content" android:layout_height="34dp"
            android:layout_gravity="center_horizontal" android:paddingHorizontal="16dp"
            android:textSize="10sp" android:textColor="#AAFFFFFF" android:backgroundTint="#14FFFFFF"
            android:layout_marginBottom="6dp" android:visibility="gone"
            style="@style/Widget.Material3.Button.OutlinedButton"/>

        <!-- AdMob banner -->
        <FrameLayout android:id="@+id/adBannerContainer"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:gravity="center" android:visibility="gone"
            android:background="#CC000000" android:paddingBottom="6dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
